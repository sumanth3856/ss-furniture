{
  "name": "ss-furniture",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
